# App
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=sdq
DB_PASSWORD=sdq_dev_password
DB_NAME=sdq_assessment
DB_SYNC=true
DB_LOGGING=false

# JWT
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Stripe (leave blank until you have keys)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_LIFETIME=
# Where Stripe redirects back to after Checkout (no trailing slash)
APP_URL=http://localhost:3000

# Subscription limits (Free plan)
FREE_PLAN_MAX_STUDENTS=10
FREE_PLAN_MAX_CLASSROOMS=1

# SMTP (leave blank to log emails to console only)
# Gmail: host=smtp.gmail.com, port=587, user=your@gmail.com, pass=<App Password>
# Mailtrap: host=sandbox.smtp.mailtrap.io, port=2525, user/pass from inbox
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SDQ Assessment <noreply@sdq-system.com>"

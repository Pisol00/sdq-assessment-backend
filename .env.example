# App
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=sdq
DB_PASSWORD=sdq_dev_password
DB_NAME=sdq_assessment
DB_SYNC=true
DB_LOGGING=false

# JWT
JWT_SECRET=change-me-to-a-long-random-string
